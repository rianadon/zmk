menuconfig ZMK_SPLIT
    bool "Split keyboard support"

if ZMK_SPLIT

config ZMK_SPLIT_ROLE_CENTRAL
    bool "Split central device"

config ZMK_SPLIT_BLE
    bool "BLE Split"
    default y
    depends on ZMK_BLE
    select BT_USER_PHY_UPDATE
    select BT_AUTO_PHY_UPDATE

config ZMK_SPLIT_WIRED
    bool "Wired Split"
    default y if !ZMK_SPLIT_BLE
    depends on DT_HAS_ZMK_WIRED_SPLIT_ENABLED
    select SERIAL
    select RING_BUFFER
    select CRC

config ZMK_SPLIT_USB
    bool "USB Split (Pico-PIO-USB on RP2040)"
    depends on SOC_RP2040
    select RING_BUFFER
    select CRC
    help
      Carry split keymap commands + events over a USB bulk pair on a
      Pico-PIO-USB interface. Central side selects UHC_PIO_USB; the
      peripheral half selects UDC_PIO_USB. The two halves communicate
      over a USB-C cable between their PIO-USB ports (e.g. the Lemon
      Wired's "Link" USB-C port pair). Phase 2 of the Lemon Wired ZMK
      roadmap.

config ZMK_SPLIT_PERIPHERAL_HID_INDICATORS
    bool "Peripheral HID Indicators"
    depends on ZMK_HID_INDICATORS
    help
      Enable propagating the HID (LED) Indicator state to the split peripheral(s).

endif # ZMK_SPLIT

rsource "bluetooth/Kconfig"
rsource "wired/Kconfig"
rsource "usb/Kconfig"
