CONFIG_SOC_SERIES_RP2XXX=y
CONFIG_SOC_RP2040=y
CONFIG_BOARD_COSMOS_LEMON_WIRED=y

CONFIG_SYS_CLOCK_HW_CYCLES_PER_SEC=125000000

# Pinctrl + GPIO
CONFIG_PINCTRL=y
CONFIG_GPIO=y

# UART for the wired-split link
CONFIG_SERIAL=y
CONFIG_UART_INTERRUPT_DRIVEN=y

CONFIG_RESET=y

# Flash + code partition
CONFIG_FLASH=y
CONFIG_FLASH_PAGE_LAYOUT=y
CONFIG_FLASH_MAP=y
CONFIG_USE_DT_CODE_PARTITION=y
CONFIG_NVS=y
CONFIG_SETTINGS_NVS=y
CONFIG_BUILD_OUTPUT_UF2=y

# Native USB device — host link.
CONFIG_USB_DEVICE_STACK=y
# CONFIG_ZMK_USB belongs in the per-shield/per-app config, not at board level
# (ZMK_USB is only defined when building inside ZMK's app tree). Set it
# through the generator's per-side .conf instead.
