/*
 * Copyright (c) 2026 The ZMK Contributors
 * SPDX-License-Identifier: MIT
 *
 * Cosmos Lemon Wired — 36-key Miryoku reference shield (COLEMAK-DH).
 *
 * Physical layout: Pumpkin Patch (R1–R3, C1–C5) for 3×5 alpha cluster,
 * Pumpkin Vine (R7, C1–C3) for the 3-key thumb cluster per side.
 *
 * The Cosmos generator produces a custom version of this file for your
 * specific keyboard layout. Use the generator output, not this file, for
 * production builds.
 *
 * Pin mapping (Lemon Wired v0.6+):
 *   Rows R1–R7: GP3–GP9   (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN, COL2ROW)
 *   Cols C1–C7: GP25, GP24, GP23, GP22, GP21, GP20, GP10  (GPIO_ACTIVE_HIGH)
 *
 * Matrix transform: 7 rows × 14 cols (cols 0–6 = left, 7–13 = right).
 * Only 36 positions are mapped; right overlay adds col-offset = <7>.
 */

#include <behaviors.dtsi>
#include <dt-bindings/zmk/matrix_transform.h>
#include <dt-bindings/zmk/keys.h>

/ {
    chosen {
        zmk,kscan = &kscan0;
        zmk,matrix-transform = &default_transform;
    };

    default_transform: keymap_transform_0 {
        compatible = "zmk,matrix-transform";
        columns = <14>;
        rows = <7>;
        // Positions 0–35 (left→right, top→bottom, then thumbs):
        //   0-4   : left top alpha    (L00–L04)
        //   5-9   : right top alpha   (R00–R04)
        //   10-14 : left home alpha   (L10–L14)
        //   15-19 : right home alpha  (R10–R14)
        //   20-24 : left bottom alpha (L20–L24)
        //   25-29 : right bottom alpha(R20–R24)
        //   30-32 : left thumbs       (LT0 outer → LT2 inner)
        //   33-35 : right thumbs      (RT0 inner → RT2 outer)
        map = <
            RC(0,0)  RC(0,1)  RC(0,2)  RC(0,3)  RC(0,4)     RC(0,7)  RC(0,8)  RC(0,9)  RC(0,10) RC(0,11)
            RC(1,0)  RC(1,1)  RC(1,2)  RC(1,3)  RC(1,4)     RC(1,7)  RC(1,8)  RC(1,9)  RC(1,10) RC(1,11)
            RC(2,0)  RC(2,1)  RC(2,2)  RC(2,3)  RC(2,4)     RC(2,7)  RC(2,8)  RC(2,9)  RC(2,10) RC(2,11)
            RC(6,0)  RC(6,1)  RC(6,2)                                 RC(6,7)  RC(6,8)  RC(6,9)
        >;
    };

    kscan0: kscan_0 {
        compatible = "zmk,kscan-gpio-matrix";
        diode-direction = "col2row";

        row-gpios
            = <&gpio0  3 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>   /* R1 */
            , <&gpio0  4 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>   /* R2 */
            , <&gpio0  5 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>   /* R3 */
            , <&gpio0  6 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>   /* R4 */
            , <&gpio0  7 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>   /* R5 */
            , <&gpio0  8 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>   /* R6 */
            , <&gpio0  9 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>   /* R7 (Pumpkin Vine thumbs) */
            ;

        col-gpios
            = <&gpio0 25 GPIO_ACTIVE_HIGH>   /* C1 */
            , <&gpio0 24 GPIO_ACTIVE_HIGH>   /* C2 */
            , <&gpio0 23 GPIO_ACTIVE_HIGH>   /* C3 */
            , <&gpio0 22 GPIO_ACTIVE_HIGH>   /* C4 */
            , <&gpio0 21 GPIO_ACTIVE_HIGH>   /* C5 */
            , <&gpio0 20 GPIO_ACTIVE_HIGH>   /* C6 */
            , <&gpio0 10 GPIO_ACTIVE_HIGH>   /* C7 */
            ;
    };
};
